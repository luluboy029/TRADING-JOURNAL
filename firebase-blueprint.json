{
  "entities": {
    "trade": {
      "title": "Trade Position",
      "description": "A single logged trade position in the trading journal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "symbol": { "type": "string" },
        "assetClass": { "type": "string", "enum": ["Crypto", "Forex", "Stocks", "Commodities", "Options"] },
        "side": { "type": "string", "enum": ["long", "short"] },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "pnl": { "type": "number" },
        "fees": { "type": "number" },
        "setup": { "type": "string" },
        "entryDate": { "type": "string", "format": "date-time" },
        "exitDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["win", "loss", "breakeven", "open"] },
        "screenshot": { "type": "string" },
        "screenshots": { "type": "array" },
        "notes": { "type": "string" },
        "riskAmount": { "type": "number" },
        "targetPrice": { "type": "number" },
        "stopLoss": { "type": "number" }
      },
      "required": ["id", "ownerId", "symbol", "assetClass", "side", "entryPrice", "quantity", "fees", "setup", "entryDate", "status", "notes"]
    }
  },
  "firestore": {
    "/trades/{tradeId}": {
      "schema": "trade",
      "description": "Collection of all trade journals logged by users."
    }
  }
}
