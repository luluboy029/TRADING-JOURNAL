rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    // Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if email is verified to prevent identity spoofing
    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function existing() {
      return resource.data;
    }
    
    // Standalone entity validator
    function isValidTrade(data) {
      return data.id is string && data.id.size() <= 128
        && data.ownerId is string && data.ownerId == request.auth.uid
        && data.symbol is string && data.symbol.size() <= 32
        && data.assetClass is string && (data.assetClass == 'Crypto' || data.assetClass == 'Forex' || data.assetClass == 'Stocks' || data.assetClass == 'Commodities' || data.assetClass == 'Options')
        && data.side is string && (data.side == 'long' || data.side == 'short')
        && data.entryPrice is number && data.entryPrice >= 0
        && data.quantity is number && data.quantity >= 0
        && data.fees is number && data.fees >= 0
        && data.setup is string && data.setup.size() <= 128
        && data.entryDate is string && data.entryDate.size() <= 64
        && data.status is string && (data.status == 'win' || data.status == 'loss' || data.status == 'breakeven' || data.status == 'open')
        && data.notes is string && data.notes.size() <= 8192
        && (!('exitPrice' in data) || data.exitPrice is number)
        && (!('pnl' in data) || data.pnl is number)
        && (!('exitDate' in data) || data.exitDate is string)
        && (!('screenshot' in data) || data.screenshot is string)
        && (!('screenshots' in data) || (data.screenshots is list && data.screenshots.size() <= 15))
        && (!('riskAmount' in data) || data.riskAmount is number)
        && (!('targetPrice' in data) || data.targetPrice is number)
        && (!('stopLoss' in data) || data.stopLoss is number);
    }

    match /trades/{tradeId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isVerifiedUser() 
        && isValidId(tradeId)
        && isValidTrade(incoming())
        && incoming().keys().hasAll(['id', 'ownerId', 'symbol', 'assetClass', 'side', 'entryPrice', 'quantity', 'fees', 'setup', 'entryDate', 'status', 'notes'])
        && incoming().keys().size() <= 20;

      allow update: if isVerifiedUser()
        && isValidTrade(incoming())
        && existing().ownerId == request.auth.uid
        && incoming().ownerId == existing().ownerId;

      allow delete: if isSignedIn()
        && existing().ownerId == request.auth.uid;
    }
  }
}
